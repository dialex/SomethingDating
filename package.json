{
  "name": "dating-guide",
  "private": true,
  "scripts": {
    "dev": "browser-sync start --server --port 3000 --files '**/*.html,**/*.js,**/*.css' --no-notify",
    "test": "playwright test --reporter=dot",
    "test:install": "playwright install --with-deps chromium",
    "test:ui": "playwright test --ui",
    "skills:install": "npx skills install",
    "skills:update": "npx skills update",
    "audit": "npx lighthouse http://localhost:3000/DatingGuide/ --view",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "browser-sync": "^3.0.4"
  }
}
